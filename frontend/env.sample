# Local development
NEXT_PUBLIC_API_URL=http://localhost:7000
NEXT_PUBLIC_AUTH_CSRF_COOKIE_NAME=csrf_token
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Must match the mode (test/live) of the backend's STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Production example (set this in Vercel Project Settings -> Environment Variables)
# NEXT_PUBLIC_API_URL=https://your-render-backend.onrender.com
